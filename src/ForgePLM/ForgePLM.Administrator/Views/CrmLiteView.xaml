<UserControl x:Class="ForgePLM.Administrator.Views.CrmLiteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>      

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Customers Card -->
            <Border Grid.Column="0"
                    Background="{StaticResource Brush.CardBackground}"
                    BorderBrush="{StaticResource Brush.CardBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.12"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Customers" Style="{StaticResource SectionTitleTextStyle}"/>
                        <Button Content="New Customer"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="16,0,0,0"
                                Click="NewCustomerButton_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0"
                             x:Name="CustomersListBox"
                             DisplayMemberPath="CustomerName"
                             SelectionChanged="CustomersListBox_SelectionChanged"/>

                        <StackPanel Grid.Column="2">
                           
                            <TextBlock Text="Customer Code"/>
                            <TextBox x:Name="CustomerCodeTextBox"/>

                            <TextBlock Text="Customer Name"/>
                            <TextBox x:Name="CustomerNameTextBox"/>

                            <TextBlock Text="Contact Name"/>
                            <TextBox x:Name="ContactNameTextBox"/>

                            <TextBlock Text="Contact Email"/>
                            <TextBox x:Name="ContactEmailTextBox"/>

                            <TextBlock Text="Contact Phone"/>
                            <TextBox x:Name="ContactPhoneTextBox"/>

                            <CheckBox x:Name="CustomerIsActiveCheckBox"
                                  Content="Active"/>

                            <Button x:Name="SaveCustomerButton"
                                Content="Create Customer"
                                Width="140"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveCustomerButton_Click"/>

                            <Border Height="1"
                                Background="#DDD"
                                Margin="0,40,0,6"/>

                            <TextBlock x:Name="CustomerIdText"
                               Grid.Row="1"
                               Text=""
                               FontSize="11"
                               FontStyle="Italic"
                               Foreground="#888"
                                VerticalAlignment="Bottom"
                               HorizontalAlignment="Left"
                               Visibility="Collapsed">
                            <Run Text="ID: "/>
                            <Run x:Name="CustomerIdValue"/>
                            </TextBlock>     
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Projects Card -->
            <Border Grid.Column="2"
                    Background="{StaticResource Brush.CardBackground}"
                    BorderBrush="{StaticResource Brush.CardBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.12"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Projects" Style="{StaticResource SectionTitleTextStyle}"/>
                        <Button Content="New Project"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="16,0,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Project Code"/>
                            <TextBox x:Name="ProjectCodeTextBox"/>

                            <TextBlock Text="Project Name"/>
                            <TextBox x:Name="ProjectNameTextBox"/>

                            <TextBlock Text="Customer"/>
                            <ComboBox x:Name="ProjectCustomerComboBox"/>

                            <CheckBox x:Name="ProjectIsActiveCheckBox"
                                      Content="Active"/>

                            <Button Content="Save Project"
                                    Width="140"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>