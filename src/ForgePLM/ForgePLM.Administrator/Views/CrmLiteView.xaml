<UserControl x:Class="ForgePLM.Administrator.Views.CrmLiteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>      

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Customers Card -->
            <Border Grid.Column="0"
                    Background="{StaticResource Brush.CardBackground}"
                    BorderBrush="{StaticResource Brush.CardBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.12"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Customers" Style="{StaticResource SectionTitleTextStyle}"/>
                        <Button Content="New Customer"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="16,0,0,0"
                                Click="NewCustomerButton_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0"
                             x:Name="CustomersListBox"
                             DisplayMemberPath="CustomerName"
                             SelectionChanged="CustomersListBox_SelectionChanged"/>

                        <StackPanel Grid.Column="2">
                           
                            <TextBlock Text="Customer Code"/>
                            <TextBox x:Name="CustomerCodeTextBox"
                             Background="{StaticResource Brush.InputBackground}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                                IsReadOnly="True"/>                          

                            <TextBlock Text="Customer Name"/>
                            <TextBox x:Name="CustomerNameTextBox"
                                 TextChanged="CustomerNameTextBox_TextChanged"/>
                            
                            <TextBlock Text="Contact Name"/>
                            <TextBox x:Name="ContactNameTextBox"/>

                            <TextBlock Text="Contact Email"/>
                            <TextBox x:Name="ContactEmailTextBox"/>

                            <TextBlock Text="Contact Phone"/>
                            <TextBox x:Name="ContactPhoneTextBox"/>

                            <CheckBox x:Name="CustomerIsActiveCheckBox"
                                  Content="Active"/>

                            <Button x:Name="SaveCustomerButton"
                                Content="Create Customer"
                                Width="140"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveCustomerButton_Click"/>

                            <Border Height="1"
                                Background="#DDD"
                                Margin="0,40,0,6"/>

                            <TextBlock x:Name="CustomerIdText"
                               Grid.Row="1"
                               Text=""
                               FontSize="11"
                               FontStyle="Italic"
                               Foreground="#888"
                                VerticalAlignment="Bottom"
                               HorizontalAlignment="Left"
                               Visibility="Collapsed">
                            <Run Text="ID: "/>
                            <Run x:Name="CustomerIdValue"/>
                            </TextBlock>     
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Projects Card -->
            <Border Grid.Column="2"
        Background="{StaticResource Brush.CardBackground}"
        BorderBrush="{StaticResource Brush.CardBorder}"
        BorderThickness="1"
        CornerRadius="14"
        Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.12"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Projects"
                       Style="{StaticResource SectionTitleTextStyle}"/>
                        <Button x:Name="NewProjectButton"
                            Content="New Project"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="16,0,0,0"
                            Click="NewProjectButton_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="ProjectsListBox"
                            Grid.Column="0"
                            SelectionChanged="ProjectsListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding ProjectCode}"
                               FontWeight="SemiBold"/>

                                            <TextBlock Grid.Column="1"
                               Text="{Binding ProjectName}"
                               Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Project Code"/>
                            
                            <TextBox x:Name="ProjectCodeTextBox"                                     
                                 Background="{StaticResource Brush.InputBackground}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                             Margin="0,4,0,12"/>

                            <TextBlock Text="Project Name"/>
                            <TextBox x:Name="ProjectNameTextBox"
                                        Margin="0,4,0,12"
                                     TextChanged="ProjectNameTextBox_TextChanged"/>

                            <TextBlock Text="Customer"/>
                            <TextBox x:Name="ProjectCustomerTextBox"
                             Margin="0,4,0,12"
                             IsReadOnly="True"/>

                            <CheckBox x:Name="ProjectIsActiveCheckBox"
                          Content="Active"
                          Margin="0,4,0,16"/>

                            <Button x:Name="SaveProjectButton"
                                Content="Save Project"
                                Width="140"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveProjectButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>