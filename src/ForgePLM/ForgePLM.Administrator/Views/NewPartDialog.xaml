<Window x:Class="ForgePLM.Administrator.Views.NewPartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Part"
        Width="700"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.WindowBackground}">

    <Border Margin="16"
            Background="{StaticResource Brush.CardBackground}"
            BorderBrush="{StaticResource Brush.CardBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Opacity="0.12"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="New Part"
                           Style="{StaticResource SectionTitleTextStyle}"/>
                <TextBlock Text="Create a new part number for the selected project and ECO."
                           Margin="0,6,0,0"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
            </StackPanel>

            <!-- Part Number / Category -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Category"
                               Style="{StaticResource FieldLabelTextStyle}"/>
                    <ComboBox x:Name="CategoryCodeComboBox"
                              Margin="0,4,0,0"
                              SelectedValuePath="CategoryCode"
                              DisplayMemberPath="CategoryCode"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Part Number"
                               Style="{StaticResource FieldLabelTextStyle}"/>
                    <TextBox x:Name="PartNumberTextBox"
                             Margin="0,4,0,0"
                             Height="30"
                             Text="#######"
                             IsReadOnly="True"
                             IsTabStop="False"/>
                </StackPanel>
                <StackPanel Grid.Column="4">

                    <TextBlock Text="Type"
                               Style="{StaticResource FieldLabelTextStyle}"/>

                    <ComboBox x:Name="DocumentTypeComboBox"
                          SelectedIndex="0"
                          Width="150" 
                          Margin="0,4,0,0"
                              >
                        <ComboBoxItem Content="PART"/>
                        <ComboBoxItem Content="ASSEMBLY"/>
                        <ComboBoxItem Content="DRAWING"/>
                    </ComboBox>
                </StackPanel>

            </Grid>

            <!-- Customer / Project -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Customer"
                               Style="{StaticResource FieldLabelTextStyle}"/>
                    <TextBox x:Name="CustomerDisplayTextBox"
                             Margin="0,4,0,0"
                             IsReadOnly="True"
                             IsTabStop="False"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Project"
                               Style="{StaticResource FieldLabelTextStyle}"/>
                    <TextBox x:Name="ProjectDisplayTextBox"
                             Margin="0,4,0,0"
                             IsReadOnly="True"
                             IsTabStop="False"/>
                </StackPanel>
            </Grid>

            <!-- ECO / Rev Family -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ECO"
                               Style="{StaticResource FieldLabelTextStyle}"/>
                    <TextBox x:Name="EcoDisplayTextBox"
                             Margin="0,4,0,0"
                             IsReadOnly="True"
                             IsTabStop="False"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Rev Family"
                               Style="{StaticResource FieldLabelTextStyle}"/>
                    <TextBlock x:Name="RevisionFamilyTextBlock"
                               Margin="0,6,0,0"
                               FontSize="16"
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- Description -->
            <StackPanel Grid.Row="8">
                <TextBlock Text="Description"
                           Style="{StaticResource FieldLabelTextStyle}"/>
                <TextBox x:Name="DescriptionTextBox"
                         Margin="0,4,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="60"
                         />
            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        x:Name="CancelButton"
                        Content="Cancel"
                        MinWidth="110"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="3"
                        x:Name="CreatePartButton"
                        Content="Create Part"
                        MinWidth="120"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="CreatePartButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>