<Window x:Class="ForgePLM.Administrator.Views.NewEcoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New ECO"
        Width="640"
        Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.WindowBackground}">

    <Border Margin="16"
            Background="{StaticResource Brush.CardBackground}"
            BorderBrush="{StaticResource Brush.CardBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Opacity="0.12"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="New ECO"
                           Style="{StaticResource SectionTitleTextStyle}"/>
                <TextBlock Text="Create a new Engineering Change Order for the selected project."
                           Margin="0,6,0,0"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
            </StackPanel>

            <!-- ECO Number + Project -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <!-- ECO Number -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="260"/>
                    <!-- ECO State -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <!-- Project -->
                </Grid.ColumnDefinitions>

                <!-- ECO Number -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ECO Number"
                   Style="{StaticResource FieldLabelTextStyle}"/>
                    <TextBox x:Name="EcoNumberTextBox"
                 Margin="0,4,0,0"
                 Text="ECO-####"
                 IsReadOnly="True"
                 IsTabStop="False"/>
                </StackPanel>

                <!-- ECO State -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="ECO State"
               Style="{StaticResource FieldLabelTextStyle}"/>

                    <Border x:Name="EcoStateBorder"
                        CornerRadius="6"
                        Padding="8,3"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Left"
                        MinWidth="110">
                        <TextBlock x:Name="EcoStateValueTextBlock"
                   FontWeight="SemiBold"
                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Project -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Project"
                   Style="{StaticResource FieldLabelTextStyle}"/>
                    <TextBox x:Name="ProjectDisplayTextBox"
                 Margin="0,4,0,0"
                 IsReadOnly="True"
                 IsTabStop="False"/>
                </StackPanel>
            </Grid>
            <!-- Rev Family -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="Rev Family"
                           Style="{StaticResource FieldLabelTextStyle}"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,6,0,0">
                    <RadioButton x:Name="RevFamily100Radio"
                                 Content="100"
                                 GroupName="RevFamily"
                                 IsChecked="True"
                                 Tag="100"
                                 VerticalAlignment="Center"/>

                    <RadioButton x:Name="RevFamily200Radio"
                                 Content="200"
                                 GroupName="RevFamily"
                                 Tag="200"
                                 Margin="18,0,0,0"
                                 VerticalAlignment="Center"/>

                    <RadioButton x:Name="RevFamily300Radio"
                                 Content="300"
                                 GroupName="RevFamily"
                                 Tag="300"
                                 Margin="18,0,0,0"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- ECO Title -->
            <StackPanel Grid.Row="6">
                <TextBlock Text="ECO Title"
                           Style="{StaticResource FieldLabelTextStyle}"/>
                <TextBox x:Name="EcoTitleTextBox"
                         Margin="0,4,0,0"/>
            </StackPanel>


            <!-- ECO Description -->
            <StackPanel Grid.Row="8">
                <TextBlock Text="ECO Description"
                           Style="{StaticResource FieldLabelTextStyle}"/>
                <TextBox x:Name="EcoDescriptionTextBox"
                         Margin="0,4,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="90"/>
            </StackPanel>

            <!-- Footer buttons -->
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                    x:Name="CancelButton"
                    Content="Cancel"
                    MinWidth="110"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click"/>

                            <Button Grid.Column="3"
                    x:Name="CreateEcoButton"
                    Content="Create ECO"
                    MinWidth="120"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="CreateEcoButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>