<UserControl x:Class="ForgePLM.Administrator.Views.ArtifactGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">


    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14" CornerRadius="10" BorderBrush="#D0D7DE" BorderThickness="1" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Customer" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ArtifactCustomerComboBox" 
                              SelectionChanged="ArtifactCustomerComboBox_SelectionChanged"                            
                              Height="32" 
                              Margin="0,4,0,0"/>
                    
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Project" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ArtifactProjectComboBox" 
                              SelectionChanged="ArtifactProjectComboBox_SelectionChanged"
                              Height="32" 
                              Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="ECO" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ArtifactEcoComboBox"
                              SelectionChanged="ArtifactEcoComboBox_SelectionChanged"
                              Height="32" 
                              Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="State" FontWeight="SemiBold"/>
                    <TextBox x:Name="ArtifactEcoStateTextBox"
                         Height="32"
                         IsReadOnly="True"
                         IsEnabled="False"
                         VerticalContentAlignment="Center"
                              Margin="0,4,0,0"
                         Text="Development"/>
                </StackPanel>
                <!--<Button x:Name="ArtifactRefreshButton" Grid.Column="8" Content="Refresh" Width="90" Height="32" VerticalAlignment="Bottom"/>-->
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="14" CornerRadius="10" BorderBrush="#D0D7DE" BorderThickness="1" Background="White">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="ECO Parts" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ArtifactSelectedCountTextBlock" Grid.Column="1" Text="0 selected" Foreground="#6B7280" VerticalAlignment="Center"/>
                    </Grid>


                    <DataGrid x:Name="ArtifactPartsGrid"
                          RowHeight="30"
                          AlternatingRowBackground="#F5F7FA"
                          AlternationCount="2"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>

                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#22C55E"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#22C55E"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>

                        </DataGrid.Resources>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                            
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                           
                            <DataGridTextColumn Header="Part"
                            Binding="{Binding DisplayCompositeCode}"
                            Width="140"
                            IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Description"
                            Binding="{Binding Description}"
                            Width="*"
                            IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>


                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Padding="14" CornerRadius="10" BorderBrush="#D0D7DE" BorderThickness="1" Background="White">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Process" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TabControl>
                        <TabItem Header="Outputs">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Output Types" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="StepAp214CheckBox" Content="STEP AP214" IsChecked="True" Margin="0,4"/>
                                    <StackPanel Margin="0,8,0,0">
                                        <CheckBox x:Name="StlCheckBox" Content="STL" Margin="0,4"/>
                                        <ComboBox x:Name="StlQualityComboBox" Height="30" Margin="22,4,0,0" SelectedIndex="1">
                                            <ComboBoxItem Content="Coarse"/>
                                            <ComboBoxItem Content="Fine"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <CheckBox x:Name="NativeCheckBox" Content="SolidWorks Native" Margin="0,12,0,4"/>
                                    <CheckBox x:Name="PdfCheckBox" Content="PDF - Drawings only" Margin="0,4"/>
                                    <Separator Margin="0,16"/>
                                    <TextBlock Text="Optional Attributes" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="AddBatchIdentifierCheckBox" Content="Add batch identifier to draft outputs" IsChecked="True" Margin="0,4"/>
                                    <CheckBox x:Name="AddDraftIndicatorCheckBox" Content="Add DRAFT indicator for Development revisions" IsChecked="True" Margin="0,4"/>
                                    <Separator Margin="0,16"/>
                                    <TextBlock Text="Actions" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="CreateZipCheckBox" Content="Create ZIP package" Margin="0,4"/>
                                    <CheckBox x:Name="ArchivePreviousCheckBox" Content="Archive previous versions" Margin="0,4"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Preview">
                            <Grid Margin="8"><TextBlock Text="eDrawings preview placeholder" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                        </TabItem>
                        <TabItem Header="History">
                            <Grid Margin="8"><TextBlock Text="Artifact history placeholder" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4" Padding="14" CornerRadius="10" BorderBrush="#D0D7DE" BorderThickness="1" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Batch Description" FontWeight="SemiBold"/>
                    <TextBox x:Name="ArtifactBatchDescriptionTextBox" Height="34" Margin="0,4,0,0" VerticalContentAlignment="Center" ToolTip="Example: Vendor quote package for Acme Manufacturing"/>

                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Bottom"
                    Margin="0,0,12,0">
                    <ProgressBar x:Name="ArtifactProgressBar"
                         Width="160"
                         Height="14"
                         IsIndeterminate="True"
                         Visibility="Collapsed"
                         Margin="0,0,8,0"/>

                    <TextBlock x:Name="ArtifactProgressTextBlock"
                       Text=""
                       VerticalAlignment="Center"
                       Foreground="#6B7280"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Validate"
                            Name="ValidateButton"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="ValidateButton_Click"/>

                    <Button Content="Generate Outputs"
                            Name="GenerateOutputsButton"
                        Width="150"
                        Height="34"
                        FontWeight="SemiBold"
                        Click="GenerateOutputsButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
