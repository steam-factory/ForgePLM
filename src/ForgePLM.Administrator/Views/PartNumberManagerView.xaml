<UserControl x:Class="ForgePLM.Administrator.Views.PartNumberManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1400">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#FFF7F7F7"
                BorderBrush="#FFD8D8D8"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock Text="Part Number Manager"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Browse all PLM-controlled part records and conditionally edit descriptions."
                               Margin="0,4,0,0"
                               Foreground="#FF555555"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <Button x:Name="RefreshButton"
                            Content="Refresh"
                            Width="110"
                            Height="34"
                            Margin="8,0,0,0"/>
                    <Button x:Name="SaveDescriptionsButton"
                            Content="Save Changes"
                            Width="130"
                            Height="34"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="2"
                Background="#FFFFFFFF"
                BorderBrush="#FFD8D8D8"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Filters"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Search"
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <TextBox x:Name="SearchTextBox"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Search part number, description, ECO, or revision"/>
                    </StackPanel>

                    <!-- Customer -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Customer"
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="CustomerFilterComboBox"
                                  Height="32"/>
                    </StackPanel>

                    <!-- Project -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Project"
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="ProjectFilterComboBox"
                                  Height="32"/>
                    </StackPanel>

                    <!-- State -->
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="State"
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="StateFilterComboBox"
                                  Height="32"/>
                    </StackPanel>

                    <!-- Document Type -->
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Document Type"
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="DocumentTypeFilterComboBox"
                                  Height="32"/>
                    </StackPanel>

                    <!-- Toggles -->
                    <StackPanel Grid.Column="9"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                        <CheckBox x:Name="CurrentOnlyCheckBox"
                                  Content="Current only"
                                  IsChecked="True"
                                  Margin="0,0,18,4"/>
                        <CheckBox x:Name="EditableOnlyCheckBox"
                                  Content="Editable only"
                                  Margin="0,0,0,4"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Grid -->
        <Border Grid.Row="4"
                Background="#FFFFFFFF"
                BorderBrush="#FFD8D8D8"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <DataGrid x:Name="PartNumbersDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      AlternatingRowBackground="#FFF8F8F8"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="36"/>
                        <Setter Property="Background" Value="#FFF2F2F2"/>
                        <Setter Property="BorderBrush" Value="#FFD8D8D8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>

                    <Style TargetType="DataGridRow">
                        <Setter Property="MinHeight" Value="34"/>    
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanEditDescription}" Value="False">
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                                <Setter Property="Background" Value="#FFF3F3F3"/>
                                <Setter Property="ToolTip" Value="Description is locked for this revision state."/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="MinHeight" Value="34"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanEditDescription}" Value="False">
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                                <Setter Property="Background" Value="#FFF3F3F3"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    

                    <DataGridTextColumn Header="Part"
                                        Binding="{Binding CompositeCode}"
                                        Width="110"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Doc Type"
                                        Binding="{Binding DocumentType}"
                                        Width="90"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="State"
                                        Binding="{Binding RevisionState}"
                                        Width="100"
                                        IsReadOnly="True"/>                

                    <DataGridTextColumn Header="ECO"
                                        Binding="{Binding EcoNumber}"
                                        Width="110"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Project"
                                        Binding="{Binding ProjectCode}"
                                        Width="120"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Customer"
                                        Binding="{Binding CustomerCode}"
                                        Width="110"
                                        IsReadOnly="True"/>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="6"
                Background="#FFF7F7F7"
                BorderBrush="#FFD8D8D8"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <DockPanel>
                <TextBlock Text="0 records"
                           x:Name="RecordCountTextBlock"
                           VerticalAlignment="Center"/>

                <TextBlock Text="Description edits are allowed only when the selected revision is in an editable state."
                           Foreground="#FF666666"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>